# Djitsotsu - Environment configuration
# Copy this file to .env and adjust as needed

# === Ports (from plan) ===
FRONTEND_PORT=4300
GATEWAY_PORT=5400
USERS_SERVICE_PORT=5401
GUILDS_SERVICE_PORT=5402
CHAT_SERVICE_PORT=5403
VOICE_SERVICE_PORT=5404
POSTGRES_PORT=5543
REDIS_PORT=6390

# === PostgreSQL ===
POSTGRES_USER=djitsotsu
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=djitsotsu

# === Redis ===
REDIS_HOST=redis
REDIS_PORT_INTERNAL=6379

# === JWT (for auth) ===
JWT_SECRET=change_me_use_strong_secret_in_production
JWT_REFRESH_SECRET=change_me_use_another_strong_secret

# === Service URLs (for gateway proxying) ===
USERS_SERVICE_URL=http://users-service:5401
GUILDS_SERVICE_URL=http://guilds-service:5402
CHAT_SERVICE_URL=http://chat-service:5403
VOICE_SERVICE_URL=http://voice-service:5404
